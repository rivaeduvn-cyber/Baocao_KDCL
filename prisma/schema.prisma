generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  role          String         @default("EMPLOYEE")     // ADMIN | EMPLOYEE — quyền hệ thống
  level         String?                                  // VIEN_TRUONG | GIAM_DOC | TRUONG_BO_PHAN | STAFF — vị trí trong cây tổ chức (null nếu Admin role không tham gia nghiệp vụ)
  managerId     String?
  position      String?                                  // chức danh hiển thị
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  manager       User?          @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates  User[]         @relation("ManagerSubordinates")
  attendances         Attendance[]
  reviewedAttendances Attendance[]   @relation("AttendanceReviewer")
  editRequests        EditRequest[]  @relation("RequesterRequests")
  reviewedEdits       EditRequest[]  @relation("ReviewerRequests")
  notifications       Notification[]

  @@index([managerId])
  @@index([level])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // EDIT_REQUEST_APPROVED | EDIT_REQUEST_REJECTED
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model Attendance {
  id         String   @id @default(cuid())
  userId     String
  date       String
  session    String
  status     String   @default("PRESENT")
  workReport String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Review (Phase 2 — chiều thuận)
  reviewStatus    String?    // null khi không có workReport; PENDING | APPROVED | NEEDS_REVISION | REJECTED
  reviewerId      String?
  reviewComment   String?
  reviewedAt      DateTime?
  autoApproveAt   DateTime?  // = createdAt + 3 ngày, dùng cho cron auto-approve
  autoApproved    Boolean    @default(false)
  delegatedFromId String?    // id của người uỷ quyền nếu reviewer là người được uỷ quyền

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer     User?         @relation("AttendanceReviewer", fields: [reviewerId], references: [id])
  attachments  Attachment[]
  editRequests EditRequest[]

  @@unique([userId, date, session])
  @@index([userId])
  @@index([date])
  @@index([reviewStatus, autoApproveAt])
  @@index([reviewerId])
}

model EditRequest {
  id            String   @id @default(cuid())
  attendanceId  String
  requesterId   String
  reviewerId    String?
  proposedStatus String?
  proposedReport String?
  reason        String
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote    String?
  createdAt     DateTime @default(now())
  reviewedAt    DateTime?

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  requester  User       @relation("RequesterRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer   User?      @relation("ReviewerRequests", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([requesterId])
  @@index([attendanceId])
}

model Attachment {
  id           String     @id @default(cuid())
  attendanceId String
  fileName     String
  fileUrl      String
  fileSize     Int
  fileType     String
  createdAt    DateTime   @default(now())
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
}
